# ── Supabase ──────────────────────────────────────────────────
# Required for auth & multi-device sync.
# Copy these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# ── AI Rally Screenshot Scanner ──────────────────────────────
# The OpenAI API key is stored as a Supabase Edge Function secret
# (never exposed to the browser). Set it with:
#
#   supabase secrets set OPENAI_API_KEY=sk-...
#   supabase functions deploy ai-vision
#
# Uses gpt-4o-mini (~$0.15/1M input tokens).
