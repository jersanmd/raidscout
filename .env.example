# ── Supabase ──────────────────────────────────────────────────
# Required for auth & multi-device sync.
# Copy these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# ── AI Rally Screenshot Scanner ──────────────────────────────
# The OpenAI API key is stored as a Supabase Edge Function secret
# (never exposed to the browser). Set it with:
#
#   supabase secrets set OPENAI_API_KEY=sk-...
#   supabase functions deploy ai-vision
#
# Uses gpt-4o-mini (~$0.15/1M input tokens).

# ── PayPal Smart Buttons ─────────────────────────────────────
# Get these from https://developer.paypal.com/
# 1. Create a REST API app → copy the Client ID
# 2. Create a Product (e.g., "RaidScout Server Subscription")
# 3. Create a Subscription Plan:
#    - Name: "RaidScout Server 30 Days"
#    - $9.99 USD / month, REGULAR, infinite cycles
#    - Copy the Plan ID (starts with "P-")
VITE_PAYPAL_CLIENT_ID=sb-your-sandbox-client-id
VITE_PAYPAL_PLAN_ID=P-your-sandbox-plan-id
